{
  "name": "threads-smart-bot",
  "version": "0.2.0",
  "description": "Threads bot that crawls trending posts, generates original Bahasa Indonesia content with OpenRouter, and publishes on demand or on a schedule — Vercel deployable",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:cron": "tsx api/cron.ts",
    "dev:auth": "tsx src/cli.ts auth",
    "dev:run": "tsx src/cli.ts run",
    "dev:run:dry": "tsx src/cli.ts run --dry"
  },
  "dependencies": {
    "@vercel/node": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
